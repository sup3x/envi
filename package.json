{
  "name": "envi-switch",
  "version": "1.0.1",
  "description": "Universal .env file manager — switch, diff, and validate environments with one command",
  "keywords": ["env", "dotenv", "environment", "cli", "devtools", "configuration", "env-manager"],
  "author": "Kerim Gülen",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/sup3x/envi" },
  "bin": { "envi": "./dist/index.js" },
  "files": ["dist"],
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run test:run && npm run build"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
